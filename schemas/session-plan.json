{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "session-plan.json",
  "title": "Session Plan — v2",
  "description": "Output of the Planner Agent. Body recomp focused. No cycle phase ceilings (OC user).",
  "type": "object",
  "required": ["date", "readiness_score", "readiness_reasoning", "session_type", "exercises", "focus_cue", "estimated_duration_minutes"],
  "properties": {
    "date": {
      "type": "string",
      "format": "date"
    },
    "training_block": {
      "type": "string",
      "description": "Current training block. e.g., 'Hypertrophy Block 1'"
    },
    "week_number": {
      "type": "integer",
      "description": "Week number within the current training block (1–8). Week 4 and 8 are deload weeks."
    },
    "is_deload": {
      "type": "boolean",
      "description": "True if this is a deload week (scheduled or auto-triggered)."
    },
    "readiness_score": {
      "type": "string",
      "enum": ["LOW", "MODERATE", "HIGH"]
    },
    "readiness_reasoning": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "signal": { "type": "string" },
          "value": { "type": "number" },
          "baseline": { "type": "string", "description": "e.g., 'mean 57 ± 4.5 SD'" },
          "deviation": { "type": "string", "description": "e.g., '-1.2 SD'" },
          "tier_assigned": { "type": "string" }
        }
      }
    },
    "pill_phase": {
      "type": "string",
      "enum": ["active", "placebo"],
      "description": "Logged for pattern detection. Does NOT affect intensity."
    },
    "session_type": {
      "type": "string",
      "enum": ["strength_lower", "strength_upper", "strength_full_body", "cardio", "recovery", "rest"],
      "description": "What kind of session this is."
    },
    "location": {
      "type": "string",
      "enum": ["home_gym", "planet_fitness"]
    },
    "warmup": {
      "type": "string",
      "description": "Prescribed warm-up protocol."
    },
    "exercises": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "sets", "notes"],
        "properties": {
          "name": { "type": "string" },
          "target_area": { "type": "string", "description": "e.g., 'hamstrings', 'triceps', 'lower abs'" },
          "sets": { "type": "integer" },
          "reps": { "type": "string" },
          "load": { "type": "string" },
          "rest_seconds": { "type": "integer" },
          "rpe_target": { "type": "integer", "minimum": 1, "maximum": 10 },
          "is_warmup_set": { "type": "boolean", "default": false },
          "notes": { "type": "string" }
        }
      }
    },
    "focus_cue": {
      "type": "string",
      "description": "One specific, actionable sentence. Not motivational."
    },
    "estimated_duration_minutes": {
      "type": "integer"
    },
    "progression_note": {
      "type": "string",
      "description": "What changed from last session and why."
    },
    "soreness_adjustments": {
      "type": "string",
      "description": "If soreness caused exercise swaps or volume changes, explain here."
    },
    "nutrition_note": {
      "type": "string",
      "description": "One-line nutrition flag if relevant. e.g., 'Training fasted — eat within 30 min after.'"
    },
    "overrides_applied": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "rule_overridden": { "type": "string" },
          "user_preference": { "type": "string" },
          "system_recommendation": { "type": "string" },
          "citation_offered": { "type": "string" }
        }
      }
    }
  }
}
